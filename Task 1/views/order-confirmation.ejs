<% title = 'Order Confirmed — ShopEasy' %>
<%- include('partials/header') %>

<div class="confirmation-box">
  <div class="confirmation-icon">✅</div>
  <h1>Thank you, <%= order.shipping.fullName %>!</h1>
  <p>Your order <strong>#<%= order.id %></strong> has been placed successfully.</p>

  <div class="order-summary">
    <h2>Order Details</h2>
    <% order.items.forEach(item => { %>
      <div class="summary-row">
        <span><%= item.name %> &times; <%= item.qty %></span>
        <span>$<%= item.subtotal.toFixed(2) %></span>
      </div>
    <% }) %>
    <hr />
    <div class="summary-row summary-total">
      <span>Total</span>
      <span>$<%= order.total.toFixed(2) %></span>
    </div>
    <p class="shipping-info">
      Shipping to: <%= order.shipping.address %>, <%= order.shipping.city %> — <%= order.shipping.phone %><br />
      Payment: <%= order.paymentMethod %> &middot; Status: <span class="status-badge"><%= order.status %></span>
    </p>
  </div>

  <div class="cart-actions">
    <a href="/" class="btn-outline">Continue Shopping</a>
    <a href="/orders" class="btn-solid">View My Orders</a>
  </div>
</div>

<%- include('partials/footer') %>
